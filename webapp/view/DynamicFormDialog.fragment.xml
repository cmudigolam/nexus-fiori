<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <Dialog id="idDynamicFormDialog" contentHeight="700px" contentWidth="900px" resizable="true" verticalScrolling="false" draggable="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="{FormData>/title}" level="H4" />
                </contentLeft>
                <contentRight>
                    <Button text="Nexus" press="onOpenNexuslink" type="Transparent" icon="sap-icon://chain-link" />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <IconTabBar id="idFormTabs" expandable="false" stretchContentHeight="true">
                <items>
                    <IconTabFilter id="idTab1" />
                    <IconTabFilter id="idTab2" />
                    <IconTabFilter id="idTab3" />
                    <IconTabFilter id="idTab4" />
                </items>
            </IconTabBar>
        </content>
        <buttons>
            <Button text="{i18n>btnSave}" press="onFormSave" type="Emphasized" />
            <Button text="{i18n>btnSaveClose}" press="onFormSaveAndClose" type="Emphasized" />
            <Button text="{i18n>btnClose}" press="onFormDialogClose" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>