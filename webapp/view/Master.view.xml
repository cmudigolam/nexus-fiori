<mvc:View controllerName="com.nexus.asset.controller.Master" xmlns="sap.m"
	xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc"   xmlns:u="sap.ui.unified"
    xmlns:semantic="sap.f.semantic" xmlns:tree="sap.ui.table" xmlns:rm="sap.ui.table.rowmodes">
    <f:DynamicPage id="dynamicPageId" toggleHeaderOnTitleClick="false" title="{i18n>assetTitle}" class="assetDynamicPage" ><!--showFooter="{LocalDataModel>/trafficLightFooterVisible}"-->
        <f:title>
            <f:DynamicPageTitle id="dynamicPageTitle">
                <f:heading>
                    <Title id="pageTitle" text="{i18n>lblAssetHierarchy}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <VBox id="mainVBox" class="assetMasterContent" height="100%">
                <HBox justifyContent="End" alignItems="Start" class="sapUiSmallMarginBottom">
                    <VBox class="sapUiSmallMarginEnd" width="22rem">
                        <Label text="{i18n>lblAsset}:" labelFor="assetSelector" class="sapUiTinyMarginBottom" />
                        <ComboBox
                            id="assetSelector"
                            width="100%"
                            placeholder="{i18n>lblSelectAsset}"
                            items="{LocalDataModel>/treeList}"
                            selectedKey="{LocalDataModel>/selectedNode}"
                            selectionChange="onNodeSelect">
                            <core:Item key="{LocalDataModel>CV_ID}" text="{LocalDataModel>Name}" />
                        </ComboBox>
                    </VBox>
                    <VBox width="16rem">
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label text="Traffic Light:" labelFor="trafficLightSelector" />
                            <core:Icon
                                id="trafficLightInfoIcon"
                                src="sap-icon://hint"
                                visible="{= !!${LocalDataModel>/selectedTrafficLight}}"
                                press="onTrafficLightInfoPress"
                                tooltip="Show traffic light details"
                                class="sapUiSmallMarginBegin"
                                color="@sapUiHighlight"
                                style="cursor:pointer" />
                        </HBox>
                        <ComboBox
                            id="trafficLightSelector"
                            width="100%"
                            placeholder="All"
                            showSecondaryValues="false"
                            items="{LocalDataModel>/trafficLightList}"
                            selectedKey="{LocalDataModel>/selectedTrafficLight}"
                            selectionChange="onTrafficLightSelect">
                            <core:Item key="{LocalDataModel>CO_ID}" text="{LocalDataModel>Name}" />
                        </ComboBox>
                    </VBox>
                </HBox>
                <tree:TreeTable
                    id="TreeTableBasic"
                    class="assetTreeTable"
                    rows="{path:'LocalDataModel>/treeTable', parameters:{arrayNames:['rows']}}"
                    alternateRowColors="true"
                    noData="{LocalDataModel>/treeTableNoDataText}"
                    selectionMode="Single"
                    selectionBehavior="RowOnly"
                    rowSelectionChange="onRowSelect"
                    toggleOpenState="onToggleOpenState"
                    enableSelectAll="false"
                    ariaLabelledBy="pageTitle">
                <tree:rowMode>
                    <rm:Fixed rowCount="{LocalDataModel>/treeTableVisibleRows}" />
                </tree:rowMode>
                <tree:columns>
                    <tree:Column id="colCategories" width="55%">
                        <Label id="lblCategories" text="{i18n>lblAssetName}"/>
                        <tree:template>
                            <Text id="txtCategoryName" text="{LocalDataModel>Name}" />
                        </tree:template>
                    </tree:Column>
                    <tree:Column id="colAssetType" width="35%">
                        <Label id="lblAssetType" text="{i18n>lblAssetType}"/>
                        <tree:template>
                            <Text id="txtAssetType" text="{LocalDataModel>AssetType}" />
                        </tree:template>
                    </tree:Column>
                    <tree:Column id="colTrafficLight" width="10%" visible="{LocalDataModel>/trafficLightColumnVisible}" hAlign="Center">
                        <Label text="T" />
                        <tree:template>
                            <core:Icon
                                src="sap-icon://circle-task-2"
                                size="1.125rem"
                                color="{parts: [{path: 'LocalDataModel>Component_ID'}, {path: 'LocalDataModel>/trafficLightVersion'}], formatter: '.formatTrafficDotColor'}"
                                visible="{parts: [{path: 'LocalDataModel>Component_ID'}, {path: 'LocalDataModel>/trafficLightVersion'}], formatter: '.formatTrafficDotVisible'}"
                                tooltip="{parts: [{path: 'LocalDataModel>Component_ID'}, {path: 'LocalDataModel>/trafficLightVersion'}], formatter: '.formatTrafficDotTooltip'}" />
                        </tree:template>
                    </tree:Column>
                </tree:columns>
            </tree:TreeTable>
            </VBox>
        </f:content>
        <f:footer>
            <Toolbar id="trafficLightLegendBar" style="Clear" height="auto">
                <FlexBox id="trafficLightLegendFlex" wrap="Wrap" alignItems="Center" width="100%">
                    <Text text="Legend:" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                </FlexBox>
            </Toolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
